#!/usr/bin/env bash
#
# pre-push hook — run the LLM-free eval gate and BLOCK the push on a >5%
# relative pass-rate regression vs the committed baseline.
#
# This is the local mirror of the GitLab CI `agent:tests` enforcement: the gate
# (agent/evals/gate.py) is stubbed / LLM-free, so it needs no API key or network
# and runs in a second or two.
#
# ACTIVATION (run once per clone; NOT done automatically so it never mutates a
# shared clone's git config behind your back):
#
#     git config core.hooksPath .githooks
#
# To bypass in an emergency:  git push --no-verify
# To deactivate:              git config --unset core.hooksPath
#
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
GATE="$REPO_ROOT/agent/evals/gate.py"

if [ ! -f "$GATE" ]; then
    echo "[pre-push] eval gate not found at agent/evals/gate.py; skipping." >&2
    exit 0
fi

# Prefer the project venv; fall back to whatever python is on PATH.
PY="$REPO_ROOT/agent/.venv/bin/python"
if [ ! -x "$PY" ]; then
    PY="$(command -v python3 || command -v python || true)"
fi
if [ -z "$PY" ]; then
    echo "[pre-push] no python interpreter found; skipping eval gate." >&2
    exit 0
fi

echo "[pre-push] running eval gate (evals/gate.py) — blocks on a >5% regression…" >&2
cd "$REPO_ROOT/agent"
exec "$PY" evals/gate.py
