%% Clinical Co-Pilot — Week 2 architecture (matches 02-architecture-spec.md)
%% Layered flowchart. Edge labels show what flows. New Week 2 parts are grouped
%% under "Agent · Week 2 additions"; reused Week 1 parts under "Agent · Week 1 (reused)".
flowchart TB
    subgraph Client["Client (agent/web · React 18 + React Aria)"]
        UP["Upload (FileTrigger)"]
        CHAT["Chat panel"]
        PROV["ProvenanceChip<br/>fhir / document / guideline"]
        OVL["SVG-over-image<br/>bbox overlay"]
        TREND["MetricChart / TrendChip<br/>(reused)"]
        STATUS["Status page<br/>(health at a glance)"]
    end

    subgraph API["API layer (FastAPI · /v1 · Caddy sole ingress)"]
        DOCS["POST /v1/documents<br/>GET /v1/documents/:id"]
        CHATAPI["POST /v1/chat"]
        READY["/health · /ready (graded)"]
    end

    subgraph Graph["Agent · Week 2 additions (copilot/graph, copilot/documents, copilot/rag)"]
        SUP["Supervisor<br/>(routes, owns parent span)"]
        IEX["Intake-extractor worker"]
        ERV["Evidence-retriever worker"]
        CRITIC["Critic<br/>(uncited / unsafe gate)"]
        PIPE["Doc pipeline<br/>pypdfium2 → Tesseract OCR →<br/>Claude vision → schema →<br/>reconcile (bbox + confidence)"]
        RAG["Hybrid RAG<br/>FTS + pgvector → RRF → rerank"]
        SCRUB["de-identify() choke-point"]
    end

    subgraph W1["Agent · Week 1 (reused)"]
        VERIFY["Verifier (fail-closed)<br/>+ document & guideline paths"]
        WRITE["Write client<br/>+ upload_document / problems / allergies"]
        FHIRC["FHIR read client"]
        AUTH["SMART session + RBAC"]
    end

    subgraph Data["Data & storage"]
        PG[("agent-postgres 16<br/>+ pgvector<br/>source_document · document_page ·<br/>extraction · extracted_fact ·<br/>guideline_chunk · audit_log")]
        OE[("OpenEMR<br/>source docs (authoritative) +<br/>confirmed clinical records")]
        CORPUS["Guideline corpus<br/>(repo files + ingest script)"]
    end

    subgraph Ext["External model providers"]
        CLAUDE["Claude<br/>(vision + chat) · PHI ok"]
        VOYAGE["Voyage embeddings<br/>(de-identified only)"]
        COHERE["Cohere rerank<br/>(de-identified only)"]
    end

    subgraph Obs["Observability"]
        LF["Langfuse v2<br/>nested spans + cost"]
    end

    subgraph CI["Eval / CI (two-tier)"]
        GATE["Stubbed PR-blocking gate<br/>50 cases · 5 boolean rubrics ·<br/>baseline + >5% · git hook"]
        LIVE["Live quality run<br/>(non-blocking)"]
    end

    UP -->|multipart HTTPS| DOCS
    CHAT -->|HTTPS| CHATAPI
    DOCS --> SUP
    CHATAPI --> SUP
    API --> AUTH

    SUP -->|"Handoff (logged)"| IEX
    SUP -->|"Handoff (logged)"| ERV
    SUP --> CRITIC
    IEX --> PIPE
    ERV --> RAG
    ERV --> SCRUB

    PIPE -->|page image + PHI| CLAUDE
    PIPE -->|store source doc| WRITE
    WRITE -->|POST /api/.../document| OE
    PIPE -->|"pages · OCR · extraction (append-only)"| PG

    SCRUB -->|topic query| VOYAGE
    RAG -->|candidates| COHERE
    RAG -->|SQL: FTS + vector| PG
    CORPUS -->|"ingest (Voyage embed, cached)"| PG

    SUP --> VERIFY
    CRITIC --> VERIFY
    VERIFY -->|re-fetch by id| FHIRC
    VERIFY -->|re-check extraction| PG
    FHIRC --> OE
    VERIFY -->|confirmed write-back| WRITE

    CHATAPI -->|claims + citations| PROV
    PROV --> OVL
    OVL -->|page image| DOCS
    CHATAPI --> TREND
    READY --> STATUS

    SUP -.spans.-> LF
    IEX -.child spans.-> LF
    ERV -.child spans.-> LF
    PG -.aggregates.-> STATUS

    GATE -.guards.-> Graph
    GATE -.guards.-> VERIFY
    LIVE -.measures.-> CLAUDE
