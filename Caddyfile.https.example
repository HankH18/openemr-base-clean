# HTTPS (domain) ingress for the AgentForge demo — OPT-IN, not the default.
#
# The default deploy uses `Caddyfile.example` (plain HTTP on :80 at a bare IP).
# This variant swaps the `:80` site label for a real domain, which makes Caddy
# provision and renew a Let's Encrypt certificate automatically (ACME HTTP-01
# needs inbound :80 AND :443 — both are published by docker-compose.deploy.yml).
# Plain-HTTP :80 requests are auto-redirected to https.
#
# Switch to this file ONLY after you have (see DEPLOY.md "Cut over to HTTPS"):
#   1. Created a DNS A-record   agentforge.<your-domain>  ->  <droplet-ip>
#   2. Ensured inbound :80 AND :443 reach the droplet.
#   3. Set BOTH of these to the SAME https origin in .env (single source of
#      truth — a mismatch is the silent SMART/redirect-URI failure class):
#        SITE_ADDR_OATH=https://agentforge.<your-domain>
#        COPILOT_PUBLIC_BASE_URL=https://agentforge.<your-domain>
#
# Then, on the droplet:
#   cp Caddyfile.https.example Caddyfile          # Caddyfile is gitignored
#   #  - replace agentforge.example.com with your real domain
#   docker compose -f docker-compose.deploy.yml --env-file .env up -d caddy agent
#
# Certificates persist in the caddy_data volume across restarts.
#
# NO basic_auth guard: per-physician SMART login is the access gate — in `smart`
# mode the agent's data routes return 401 without an authenticated session, so
# the app is never exposed unauthenticated and users hit only the OpenEMR login.
# (If you ever run HTTPS with COPILOT_AUTH_MODE=disabled, add a
# `basic_auth { user <bcrypt-hash> }` block back inside the site as a network
# guard — generate the hash with
# `docker run --rm caddy caddy hash-password --plaintext 'PW'`.)

agentforge.example.com {
	# Scanned-PDF uploads (POST /v1/documents) can be large. Caddy's default body
	# cap (~10KB for buffered reads) would reject them, so raise the limit well
	# above the documented 10MB upload ceiling for the whole site.
	request_body {
		max_size 25MB
	}

	# OpenEMR OAuth2 / login surface — REQUIRED for per-physician SMART login.
	# The physician's browser is redirected to OpenEMR's /oauth2/default/authorize
	# and logs in there; these paths must reach OpenEMR, not the SPA. One prefix
	# (/oauth2/*) covers authorize, provider/login, login, smart/patient-select,
	# scope-authorize-confirm, device/code, token, jwk, .well-known, registration.
	# /public/* and /library/* serve the login/consent page assets (css/js/fonts).
	# Must precede the SPA catch-all.
	@openemr {
		path /oauth2/* /public/* /library/* /custom/*
	}
	handle @openemr {
		reverse_proxy openemr
	}

	# Agent API → internal agent service (same-origin; the SPA calls /v1/*)
	# /status is the documented bare-path health page (week2.yaml); /v1/status is
	# already covered by /v1/*, but the un-versioned alias needs listing here or it
	# falls through to the SPA.
	@api {
		path /v1/* /status /health /ready /openapi.json /docs /docs/*
	}
	handle @api {
		reverse_proxy agent:8000
	}

	# Everything else → the SPA, with client-side routing fallback
	handle {
		root * /srv/dist
		try_files {path} /index.html
		file_server
	}
}
