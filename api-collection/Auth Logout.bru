meta {
  name: Auth Logout
  type: http
  seq: 13
}

post {
  url: {{baseUrl}}/v1/auth/logout
  body: none
  auth: none
}

docs {
  POST /v1/auth/logout — 204 always. Clears the af_session cookie and, in smart
  mode with a live session, best-effort revokes it server-side. Safe to call in
  disabled mode (just clears any stray cookie).
}
