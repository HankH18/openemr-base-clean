meta {
  name: Rounds Current
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/v1/rounds/current?clinician_id={{clinician_id}}
  body: none
  auth: none
}

params:query {
  clinician_id: {{clinician_id}}
}

docs {
  GET /v1/rounds/current — re-read the clinician's current patient card from the
  persisted cursor. 404 "No active rounding session" if none. Pure DB read (no
  LLM, no FHIR) — a process restart resumes exactly where it left off.
}
