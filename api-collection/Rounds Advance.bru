meta {
  name: Rounds Advance
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/v1/rounds/advance
  body: json
  auth: none
}

body:json {
  {
    "clinician_id": {{clinician_id}},
    "completed_patient_id": 101
  }
}

docs {
  POST /v1/rounds/advance — mark the current patient seen and move the cursor to
  the next. Returns the next card, or { "done": true } when the list is
  exhausted. 404 if no active round.
}
