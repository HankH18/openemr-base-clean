# Copy this file to `.env` next to docker-compose.deploy.yml and fill in
# real values.  NEVER commit `.env` — it is ignored via the repo's
# gitignore rules (see .gitignore).  These variables are consumed by
# docker-compose.deploy.yml at `up` time.

# ---- Required ----------------------------------------------------------

# Public URL where users (and OAuth clients) reach OpenEMR. Use the
# droplet IP for a bare-IP demo, or the DNS name once one exists. The
# scheme must match how users actually connect — http for now, https
# after Caddy/TLS is in front (Task 6).
SITE_ADDR_OATH=http://REPLACE-WITH-DROPLET-IP

# MariaDB root password. Long, random, unique.
MYSQL_ROOT_PASSWORD=REPLACE-WITH-STRONG-RANDOM-PASSWORD

# OpenEMR's own DB user password (application login to MariaDB).
MYSQL_PASSWORD=REPLACE-WITH-ANOTHER-STRONG-RANDOM-PASSWORD

# First-boot OpenEMR admin credentials. The default `admin`/`pass` from
# the dev stack MUST NOT be used for a public deploy — leaving it will
# fail the audit's security dimension.
OE_USER=admin
OE_PASS=REPLACE-WITH-A-REAL-ADMIN-PASSWORD

# ---- Optional ----------------------------------------------------------

# Host user id apache should adopt for anything it writes to bind mounts
# on the host.  Ubuntu 22.04 droplets typically have root=0 as the SSH
# user; 1000 is fine because this deploy has no source bind-mounts.
# HOST_UID=1000
# HOST_GID=1000
