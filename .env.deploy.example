# Copy this file to `.env` next to docker-compose.deploy.yml and fill in
# real values.  NEVER commit `.env` — it is ignored via the repo's
# gitignore rules (see .gitignore).  These variables are consumed by
# docker-compose.deploy.yml at `up` time.

# ---- Required ----------------------------------------------------------

# Public URL where users (and OAuth clients) reach OpenEMR. Use the
# droplet IP for a bare-IP demo, or the DNS name once one exists. The
# scheme MUST match how users actually connect — http://<ip> for the
# default bare-IP demo, https://agentforge.<your-domain> after you cut
# over to the domain/TLS Caddyfile (see DEPLOY.md "Cut over to HTTPS").
# When HTTPS: this and COPILOT_PUBLIC_BASE_URL below must be the SAME
# https origin — a mismatch is the silent SMART/redirect-URI failure class.
SITE_ADDR_OATH=http://REPLACE-WITH-DROPLET-IP

# MariaDB root password. Long, random, unique.
MYSQL_ROOT_PASSWORD=REPLACE-WITH-STRONG-RANDOM-PASSWORD

# OpenEMR's own DB user password (application login to MariaDB).
MYSQL_PASSWORD=REPLACE-WITH-ANOTHER-STRONG-RANDOM-PASSWORD

# First-boot OpenEMR admin credentials. The default `admin`/`pass` from
# the dev stack MUST NOT be used for a public deploy — leaving it will
# fail the audit's security dimension.
OE_USER=admin
OE_PASS=REPLACE-WITH-A-REAL-ADMIN-PASSWORD

# ---- Agent service (copilot) -------------------------------------------

# Postgres password for the agent-owned DB. Strong random, unique.
AGENT_POSTGRES_PASSWORD=REPLACE-WITH-STRONG-RANDOM-PASSWORD

# OAuth client IDs registered inside OpenEMR (admin UI). JWKs URL is
# supplied out-of-band — never in this file. Leave blank until the
# operator has registered the clients.
SMART_APP_CLIENT_ID=
BACKEND_SERVICES_CLIENT_ID=

# Secret for the CONFIDENTIAL SMART login client (printed by
# scripts/register_smart_app_client.py alongside the client_id — see
# DEPLOY.md §16.1). REQUIRED when COPILOT_AUTH_MODE=smart: the code
# exchange authenticates with client_secret_basic, so without it every
# login dies at the last step with invalid_client — after the physician
# has already signed in and consented. The agent refuses to boot in smart
# mode without it. Secrets-manager only; never commit a filled-in value.
#
# NOTE the variable name: docker-compose.deploy.yml interpolates
# ${SMART_APP_CLIENT_SECRET} (no COPILOT_ prefix) and passes it to the
# container as COPILOT_SMART_APP_CLIENT_SECRET. Setting
# `COPILOT_SMART_APP_CLIENT_SECRET=` in this file does NOTHING — compose
# never reads that name. Same for SMART_APP_CLIENT_ID above.
SMART_APP_CLIENT_SECRET=

# LLM (Claude via Anthropic API). Without this the agent runs in a
# degraded mode: /ready reports llm=not_ready and synthesis raises.
ANTHROPIC_API_KEY=
# Real model ids (the code defaults are also valid; override only to change tier).
ANTHROPIC_MODEL_SYNTHESIS=claude-sonnet-5
ANTHROPIC_MODEL_GATING=claude-haiku-4-5-20251001

# ---- Hybrid RAG + multi-agent graph (optional; keyless by default) -----
# All three are OPTIONAL and the deployed default (see DEPLOY.md §18): unset,
# embeddings/rerank use deterministic keyless STUBS and chat runs the inline
# (non-graph) path — retrieval still returns grounded, cited guideline evidence.
# Set them only to enable real hybrid RAG / the supervisor-worker-critic graph.
# NOTE the names: compose interpolates ${VOYAGE_API_KEY} / ${COHERE_API_KEY}
# (no COPILOT_ prefix) and passes them as COPILOT_VOYAGE_API_KEY /
# COPILOT_COHERE_API_KEY — setting the prefixed names here does NOTHING.
#
# Real voyage-3.5 embeddings for dense guideline retrieval (else keyless stub).
#VOYAGE_API_KEY=
# Real rerank-v3.5 reranking of fused retrieval results (else keyless stub).
#COHERE_API_KEY=
# Route serve-time chat through the supervisor/worker/critic graph (default false).
#COPILOT_CHAT_GRAPH_ENABLED=false

# ---- Backend Services client (register on the DEPLOYED OpenEMR) --------
# scripts/register_backend_client.py registers the client + writes the key.
# The scope set MUST match what the client was registered with.
BACKEND_SERVICES_SCOPES=system/Patient.read system/Observation.read system/MedicationRequest.read system/Condition.read system/AllergyIntolerance.read system/Encounter.read system/DiagnosticReport.read
# Host path to the client private key PEM (mounted read-only into the agent).
BACKEND_KEY_PATH=./secrets/backend-key.pem
# Only when demoing on the seeded cohort (maps integer pid -> the seed's UUIDs):
FHIR_PATIENT_ID_TEMPLATE=

# ---- Poller: run the background loop in the agent (default off) --------
POLLER_ENABLED=false

# ---- Langfuse (optional; leave blank to keep observability a no-op) ----
# All three needed for Langfuse to be considered configured; leaving any
# blank makes tracing a silent no-op.
#   - Cloud:       LANGFUSE_HOST=https://us.cloud.langfuse.com (or EU)
#   - Self-hosted: LANGFUSE_HOST=http://langfuse:3000  (the in-network name of
#                  the opt-in `observability`-profile service; see below)
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ---- Self-hosted Langfuse (only if using `--profile observability`) ----
# Keeps PHI-adjacent traces on the droplet instead of Langfuse Cloud. These
# are consumed by the profiled langfuse / langfuse-postgres services; they are
# IGNORED unless you bring that profile up. Set them BEFORE enabling it — the
# services fail loud (empty Postgres password / missing secret) rather than
# booting insecurely. See agent/LANGFUSE_SETUP.md "Self-hosted (droplet)".
#   openssl rand -base64 32   # for each of the three below
LANGFUSE_POSTGRES_PASSWORD=
NEXTAUTH_SECRET=
SALT=
# UI origin for the self-hosted Langfuse. Default (unset) assumes SSH-tunnel-
# only access; set a public https URL only if you front the UI with Caddy.
# LANGFUSE_NEXTAUTH_URL=http://localhost:3000

# ---- Public origin + per-physician SMART login (opt-in) ----------------
# COPILOT_PUBLIC_BASE_URL is the single source of truth for the browser-facing
# origin: the SMART redirect_uri and the post-login redirect are built from it.
# Leave blank for the default no-login demo. When cutting over to HTTPS + SMART
# it MUST equal SITE_ADDR_OATH (both = https://agentforge.<your-domain>).
COPILOT_PUBLIC_BASE_URL=
# Identity model. "disabled" (default) = no login, clinician_id from the
# request (current demo, byte-for-byte). "smart" = per-physician SMART login.
# In smart mode the agent REFUSES TO BOOT unless all of these hold:
#   - COPILOT_PUBLIC_BASE_URL is https
#   - COPILOT_SESSION_ENC_KEY is set (below)
#   - SMART_APP_CLIENT_ID + SMART_APP_CLIENT_SECRET are set (above)
#   - COPILOT_OAUTH_AUTHORIZE_URL is a public https endpoint (below)
COPILOT_AUTH_MODE=disabled

# Where the PHYSICIAN'S BROWSER is sent to sign in. Defaults (in compose) to
# the internal http://openemr/oauth2/default/authorize, which is correct ONLY
# for the auth_mode=disabled demo — no browser is ever redirected there.
#
# When COPILOT_AUTH_MODE=smart this MUST be the PUBLIC https authorize
# endpoint, or the physician's browser is sent to an internal Docker hostname
# that resolves nowhere. With the HTTPS Caddyfile, /oauth2/* is proxied to
# OpenEMR on the public origin, so this is normally:
#   COPILOT_OAUTH_AUTHORIZE_URL=https://agentforge.<your-domain>/oauth2/default/authorize
# (COPILOT_OAUTH_TOKEN_URL is deliberately NOT this — the token exchange is a
# server-side back-channel and stays on the internal http://openemr host.)
COPILOT_OAUTH_AUTHORIZE_URL=
# Fernet key that encrypts physician OAuth tokens at rest (required when
# auth_mode=smart). Secrets-manager only; never commit. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
COPILOT_SESSION_ENC_KEY=

# ---- Audit retention (HIPAA §164.312(b) — 6-year floor) ----------------
# The retention sweep REFUSES to delete any audit_log row younger than this.
# Never set below 6 for a compliant deployment.
COPILOT_AUDIT_RETENTION_YEARS=6

# ---- Optional ----------------------------------------------------------

# Host user id apache should adopt for anything it writes to bind mounts
# on the host.  Ubuntu 22.04 droplets typically have root=0 as the SSH
# user; 1000 is fine because this deploy has no source bind-mounts.
# HOST_UID=1000
# HOST_GID=1000

# --- Optional agent tuning (all safe to leave unset) -------------------------
#
# Every knob below is OPTIONAL: leave it blank and the code's default applies.
# (An empty value means "unset" — Settings drops blanks for typed fields, so the
# standard `${VAR:-}` compose idiom cannot brick the boot.)

# Ingestion limits. These are what stop a 544-BYTE pdf declaring a 60x60in page
# from rendering to 1.1 GB and OOM-killing the box. Raise them ONLY on a larger
# box, and raise the agent's mem_limit in docker-compose.deploy.yml to match.
#COPILOT_OCR_DPI=200                       # render DPI. Raising this scales pixels quadratically.
#COPILOT_RASTER_MAX_PAGE_PIXELS=50000000   # 50 MP: 6.7x a tabloid page and 1.67x ANSI D at 200 DPI.
#COPILOT_RASTER_MAX_PAGES=1000             # a long discharge summary is genuinely 50-100pp.
#COPILOT_VISION_MAX_PAGES_PER_CALL=20      # >20 images triggers a stricter 2000px/image API limit,
                                           # and 200 DPI renders a page at 2200px — so 21 would be
                                           # REJECTED outright. Only raise below ocr_dpi 181.

# Keyed digest for the patient pseudonym on Langfuse traces.
# UNSET IS THE SAFE DEFAULT: with no key the backend DROPS patient_id entirely
# rather than emit a per-process id that changes on restart (grouping by that
# would read one patient as two). Set it only if you want traces groupable by
# patient across restarts; the third party never sees a raw id either way.
# NOTE: a pseudonym is NOT de-identification under 45 CFR 164.514(c) — an HMAC of
# the id is still "derived from" the individual, so a Langfuse dataset carrying it
# remains PHI and needs a BAA.
#COPILOT_OBSERVABILITY_PSEUDONYM_KEY=

#COPILOT_TLS_VERIFY=true                   # only set false for a local self-signed dev stack.
#COPILOT_CHAT_RETENTION_DAYS=
#COPILOT_SESSION_IDLE_SECONDS=
#COPILOT_SESSION_ABSOLUTE_SECONDS=
